{
  "name": "markdown-editor",
  "version": "1.0.2",
  "description": "跨平台 Markdown 编辑器，支持实时预览、文件管理、图片粘贴",
  "author": "Markdown Editor Team",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "vite & sleep 2 && electron .",
    "electron:build": "vite build --base ./ && electron-builder --win nsis",
    "electron:build:mac": "vite build --base ./ && electron-builder --mac",
    "electron:build:all": "vite build --base ./ && electron-builder --win nsis --mac",
    "electron:preview": "vite build && electron ."
  },
  "build": {
    "appId": "com.markdown-editor.app",
    "productName": "Markdown Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "Markdown编辑器-v${version}-macOS-${arch}.${ext}",
      "extendInfo": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Markdown File",
            "CFBundleTypeRole": "Editor",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": [
              "net.daringfireball.markdown"
            ],
            "CFBundleTypeExtensions": [
              "md"
            ]
          }
        ],
        "UTImportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "net.daringfireball.markdown",
            "UTTypeTagSpecification": {
              "public.filename-extension": "md"
            },
            "UTTypeDescription": "Markdown File",
            "UTTypeConformsTo": [
              "public.text",
              "public.plain-text"
            ]
          }
        ]
      }
    },
    "dmg": {
      "artifactName": "Markdown编辑器-v${version}-macOS-${arch}.${ext}",
      "title": "Markdown Editor ${version}",
      "icon": "build/icon.png",
      "window": {
        "width": 500,
        "height": 400
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "artifactName": "Markdown编辑器-v${version}-安装包.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Markdown 编辑器",
      "uninstallDisplayName": "Markdown 编辑器"
    }
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@highlightjs/vue-plugin": "^2.1.0",
    "element-plus": "^2.9.0",
    "highlight.js": "^11.11.0",
    "marked": "^15.0.0",
    "turndown": "^7.2.4",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "sass": "^1.83.0",
    "typescript": "^5.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  }
}
